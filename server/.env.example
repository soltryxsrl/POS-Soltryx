# ============================================
# T1ET POS - server (NestJS)
# ============================================

# --- Database (Postgres) ---
DB_HOST=localhost
DB_PORT=5433
DB_NAME=t1et_pos
DB_USER=t1et_app
DB_PASSWORD=12345678
DB_SCHEMA=public

# --- API ---
API_PORT=3001
API_HOST=0.0.0.0
NODE_ENV=development
TZ=America/Santo_Domingo

# --- Auth (JWT) ---
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-aaaaaaaaa
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-bbbbbbbb
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- CORS / Cookies ---
WEB_ORIGIN=http://localhost:3000
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false
